{
  "location": "eastus2",
  "properties": {
    "dataSources": {
      "performanceCounters": [
        {
          "name": "vmInsightsPerfCounters",
          "streams": [
            "Microsoft-InsightsMetrics"
          ],
          "samplingFrequencyInSeconds": 60,
          "counterSpecifiers": [
            "\\VmInsights\\DetailedMetrics"
          ]
        }
      ],
      "extensions": [
        {
          "name": "DependencyAgentDataSource",
          "streams": [
            "Microsoft-ServiceMap"
          ],
          "extensionName": "DependencyAgent"
        }
      ]
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "<LAW_ResourceID>",
          "name": "la-dest"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Microsoft-InsightsMetrics"
        ],
        "destinations": [
          "la-dest"
        ]
      },
      {
        "streams": [
          "Microsoft-ServiceMap"
        ],
        "destinations": [
          "la-dest"
        ]
      }
    ]
  }
}
